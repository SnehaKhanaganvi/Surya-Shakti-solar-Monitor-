<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/solar_black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Generation Log"
            android:textColor="@color/solar_yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/solar_dark_gray"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Manual kWh input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Today's Generation (kWh)"
                    android:layout_marginBottom="12dp"
                    app:boxStrokeColor="@color/solar_yellow"
                    app:hintTextColor="@color/solar_yellow"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGeneration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Panel Capacity -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Panel Capacity (kWp)"
                    android:layout_marginBottom="12dp"
                    app:boxStrokeColor="@color/solar_yellow"
                    app:hintTextColor="@color/solar_yellow"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPanelCapacity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="3.0"
                        android:textColor="@color/white" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Weather Chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weather Condition"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chipSunny"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="☀️ Sunny"
                        android:textColor="@color/solar_black"
                        android:textSize="12sp"
                        app:backgroundTint="@color/solar_yellow"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chipPartlyCloudy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:text="⛅ Partly"
                        android:textColor="@color/solar_black"
                        android:textSize="12sp"
                        android:alpha="0.4"
                        app:backgroundTint="@color/solar_yellow_dark"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chipCloudy"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="☁️ Cloudy"
                        android:textColor="@color/solar_black"
                        android:textSize="12sp"
                        android:alpha="0.4"
                        app:backgroundTint="@color/text_secondary"
                        app:cornerRadius="20dp" />
                </LinearLayout>

                <!-- Simulate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimulate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:text="🔄 Simulate Generation"
                    android:textColor="@color/solar_black"
                    app:backgroundTint="@color/solar_yellow_dark"
                    app:cornerRadius="8dp" />

                <!-- Sim Info -->
                <TextView
                    android:id="@+id/tvSimInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:paddingBottom="8dp"
                    android:background="#1A1A1A"
                    android:padding="8dp" />

                <!-- Tip -->
                <TextView
                    android:id="@+id/tvTip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/solar_yellow"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:paddingBottom="8dp"
                    android:padding="8dp" />

                <!-- Save Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="💾 Save Generation"
                    android:textColor="@color/solar_black"
                    android:textStyle="bold"
                    app:backgroundTint="@color/solar_yellow"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bar Chart: Last 14 days -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Last 14-Day Generation"
            android:textColor="@color/solar_yellow"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/barChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
