<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/solar_black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="☀️ Surya-Shakti"
            android:textColor="@color/solar_yellow"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Solar Energy Dashboard"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Circular Progress Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/solar_dark_gray"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <com.suryashakti.solarmonitor.custom.CircularProgressView
                    android:id="@+id/circularProgress"
                    android:layout_width="160dp"
                    android:layout_height="160dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Green Score"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvGreenScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/solar_green"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 100"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/solar_black"
                        android:layout_marginVertical="8dp" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log your generation to begin"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Generated -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/solar_dark_gray"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡ Generated" android:textColor="@color/solar_yellow" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvGenerated" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.0 kWh"
                        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Consumed -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/solar_dark_gray"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔌 Consumed" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvConsumed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.0 kWh"
                        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Net Energy + Savings Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/solar_dark_gray"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Net Energy" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvNetEnergy" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.0 kWh"
                        android:textColor="@color/solar_green" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="@color/solar_dark_gray"
                app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💰 Savings" android:textColor="@color/solar_yellow" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvSavings" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₹0.00"
                        android:textColor="@color/solar_yellow" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Over-generation card (hidden by default) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardOvergeneration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1A2E1A"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/solar_green"
            app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚀 Over-Generation — Prosumer Mode!"
                    android:textColor="@color/solar_green" android:textStyle="bold" android:textSize="14sp"/>
                <TextView android:id="@+id/tvExportEarnings" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:paddingTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Weather & Battery Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/solar_dark_gray"
            app:cardCornerRadius="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Weather Today"
                        android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvWeather" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Not simulated"
                        android:textColor="@color/solar_yellow" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSimulateWeather"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:text="🌤 Simulate Weather &amp; Generate"
                    android:textColor="@color/solar_black"
                    app:backgroundTint="@color/solar_yellow"
                    app:cornerRadius="8dp" />

                <!-- Battery Level Slider -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔋 Battery Level" android:textColor="@color/text_secondary"
                    android:textSize="12sp" android:paddingTop="12dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderBattery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:value="0"
                        android:stepSize="1"
                        app:thumbColor="@color/solar_yellow"
                        app:trackColorActive="@color/solar_yellow"
                        app:trackColorInactive="@color/solar_black" />
                    <TextView android:id="@+id/tvBatteryPct" android:layout_width="40dp"
                        android:layout_height="wrap_content" android:text="0%"
                        android:textColor="@color/solar_yellow" android:textSize="13sp"
                        android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Peak Alert Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPeakAlert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="10dp"
            android:text="🔔 Send Peak Sun Alert"
            android:textColor="@color/solar_yellow"
            app:backgroundTint="@color/solar_dark_gray"
            app:strokeColor="@color/solar_yellow"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

        <!-- Quick Nav Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoGeneration"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginEnd="4dp"
                android:text="⚡ Log Gen" android:textSize="11sp"
                android:textColor="@color/solar_black"
                app:backgroundTint="@color/solar_yellow" app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoConsumption"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginHorizontal="4dp"
                android:text="🔌 Consumption" android:textSize="11sp"
                android:textColor="@color/solar_black"
                app:backgroundTint="@color/solar_yellow_dark" app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoSavings"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="4dp"
                android:text="📊 Savings" android:textSize="11sp"
                android:textColor="@color/solar_black"
                app:backgroundTint="@color/solar_orange" app:cornerRadius="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
