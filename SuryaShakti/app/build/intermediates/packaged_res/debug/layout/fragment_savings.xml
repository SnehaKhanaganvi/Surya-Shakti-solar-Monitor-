<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/solar_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 30-Day Savings Report"
            android:textColor="@color/solar_yellow"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Summary Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/solar_dark_gray"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Summary"
                    android:textColor="@color/solar_yellow"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="12dp" />

                <!-- Row 1: Generated & Consumed -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚡ Total Generated" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvTotalGenerated" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.00 kWh"
                            android:textColor="@color/solar_yellow" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔌 Total Consumed" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvTotalConsumed" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0.00 kWh"
                            android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2: Savings & Green Score -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰 Total Savings" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvTotalSavings" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0.00"
                            android:textColor="@color/solar_green" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌱 Avg Green Score" android:textColor="@color/text_secondary" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvAvgGreenScore" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textColor="@color/solar_green" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Over-gen days -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🚀 Over-generation days: " android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvOverGenDays" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0 day(s)"
                        android:textColor="@color/solar_green" android:textSize="12sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Line Chart -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📈 Generation vs Consumption (14 Days)"
            android:textColor="@color/solar_yellow"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No energy logs yet.\nGo to Generation and log your first entry!"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp" />

        <!-- Daily Log RecyclerView -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Daily Log"
            android:textColor="@color/solar_yellow"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSavings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
